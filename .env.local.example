# Copy to .env.local and fill in. Never commit .env.local.

# Claude API key — used by both /api/assistant (Ask ONA site assistant)
# and /api/claimlens/analyze (ClaimLens™ AI claim review). Get one at
# https://console.anthropic.com/.
# Without this, both routes return deterministic mocks so the UI is reviewable.
ANTHROPIC_API_KEY=

# Supabase — backs ClaimLens™ authentication, claim storage, and the
# private claim-files bucket. Get these from Supabase dashboard:
#   - Project URL: Settings → General → Project ID (URL is https://<id>.supabase.co)
#   - Anon / publishable key: Settings → API Keys → Publishable key
#   - Service role / secret key: Settings → API Keys → New secret key
# The first two are safe in the client bundle (RLS protects data).
# SUPABASE_SERVICE_ROLE_KEY bypasses RLS — server-only, never expose.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string — used by `npm run migrate` to apply SQL
# migrations from supabase/migrations/*.sql. Get it from Supabase
# dashboard: Project Settings → Database → Connection string → URI tab.
# Replace [YOUR-PASSWORD] with the database password you set when
# creating the Supabase project. Not read by the Next.js app at runtime.
SUPABASE_DB_URL=

# Plausible Analytics (cookieless, no consent banner needed).
# Leave empty in dev. In prod, set to the registered domain in Plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Self-hosted Plausible? Override the host. Default: https://plausible.io
# NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.example.com

# Sentry error tracking (optional). Get the DSN from a new Sentry project:
# https://sentry.io/ → Create Project → "Next.js" → copy the DSN.
# Both vars point at the same project; Sentry exposes the DSN to both
# server and browser, but Next requires the NEXT_PUBLIC_ prefix for any
# value that ships in the client bundle.
# Without these, sentry.*.config.ts files no-op (errors go to Vercel logs
# only). The integration is safe to ship without a DSN.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
