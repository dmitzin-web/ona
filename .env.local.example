# Copy to .env.local and fill in. Never commit .env.local.

# Claude API key — used by /api/assistant (the Ask ONA site assistant).
# Get one at https://console.anthropic.com/.
# Without this, /api/assistant returns a deterministic mock so the UI is
# still reviewable in dev.
ANTHROPIC_API_KEY=

# Upstash Redis — per-IP rate limiting for /api/assistant (the public,
# unauthenticated endpoint that calls the paid Claude model).
# Create a database at https://console.upstash.com/ and paste the REST URL +
# token below. Without these, rate limiting is DISABLED (requests pass
# through) so the UI stays exercisable in dev — but production should set them.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# NOTE: The Vercel Marketplace Upstash/KV integration instead provisions
# KV_REST_API_URL / KV_REST_API_TOKEN automatically — lib/rate-limit.ts reads
# those as a fallback, so on Vercel you usually don't set anything by hand.

# Plausible Analytics (cookieless, no consent banner needed).
# Leave empty in dev. In prod, set to the registered domain in Plausible.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# Self-hosted Plausible? Override the host. Default: https://plausible.io
# NEXT_PUBLIC_PLAUSIBLE_HOST=https://plausible.example.com
